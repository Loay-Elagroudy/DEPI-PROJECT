# Copy to backend/.env (backend reads relative to its own working directory)

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Gemini (Milestone 2 generation model) ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Embeddings (Milestone 2, cell 35) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Data / vector store ---
DATA_CSV_PATH=./data/processed_corpus_5000.csv
CHROMA_PERSIST_DIR=./models/chromadb_index
CHROMA_COLLECTION_NAME=complaints_rag

# --- Vector store build ---
MAX_ROWS=5000
BATCH_SIZE=1000

# --- Retrieval defaults ---
RETRIEVER_TOP_K=3
RETRIEVER_SEARCH_TYPE=similarity

# --- CORS ---
CORS_ORIGINS=*

# --- Frontend ---
API_BASE_URL=http://localhost:8000
